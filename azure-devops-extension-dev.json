{
    "manifestVersion": 1,
    "id": "copilot-failure-analysis-dev",
    "publisher": "returngisorg",


    "version": "0.22.2",
    "name": "GitHub Copilot Pipeline Failure Analyzer [DEV]",
    "description": "Automatically analyzes pipeline failures using AI and provides root cause analysis with fix suggestions. (Development version)",
    "categories": ["Azure Pipelines"],
    "targets": [
        { "id": "Microsoft.VisualStudio.Services" }
    ],
    "scopes": ["vso.build"],
    "icons": {
        "default": "logo.png"
    },
    "content": {
        "details": { "path": "overview.md" }
    },
    "contributions": [
        {
            "id": "copilot-failure-analysis-decorator",
            "type": "ms.azure-pipelines.pipeline-decorator",
            "targets": [
                "ms.azure-pipelines-agent-job.post-job-tasks"
            ],
            "properties": {
                "template": "decorator/copilot-failure-analysis.yml"
            }
        },
        {
            "id": "copilot-test-decorator",
            "type": "ms.azure-pipelines.pipeline-decorator",
            "targets": [
                "ms.azure-pipelines-agent-job.post-job-tasks"
            ],
            "properties": {
                "template": "decorator/test-decorator.yml"
            }
        },
        {
            "id": "copilot-failure-analysis-task",
            "type": "ms.vss-distributed-task.task",
            "targets": [
                "ms.vss-distributed-task.tasks"
            ],
            "properties": {
                "name": "copilot-failure-analysis-task"
            }
        },
        {
            "id": "copilot-failure-analysis-tab",
            "type": "ms.vss-build-web.build-results-tab",
            "description": "Shows Copilot failure analysis results in a dedicated tab",
            "targets": [
                "ms.vss-build-web.build-results-view"
            ],
            "properties": {
                "name": "🤖 Copilot Failure Analysis",
                "uri": "copilot-analysis-tab/tab.html",
                "supportsMobile": false,
                "order": 100
            }
        }
    ],
    "files": [
        {
            "path": "decorator/copilot-failure-analysis.yml",
            "addressable": true,
            "contentType": "text/plain"
        },
        {
            "path": "decorator/test-decorator.yml",
            "addressable": true,
            "contentType": "text/plain"
        },
        {
            "path": "dist/copilot-failure-analysis-task",
            "packagePath": "copilot-failure-analysis-task"
        },
        {
            "path": "copilot-analysis-tab",
            "addressable": true
        }
    ]
}
