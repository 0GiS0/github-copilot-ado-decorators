{
  "name": "github-copilot-ado-decorators",
  "version": "0.1.0",
  "description": "Azure DevOps Pipeline Decorator Extension — GitHub Copilot Failure Analysis",
  "author": "returngisorg",
  "license": "MIT",
  "private": true,
  "scripts": {
    "compile": "tsc",
    "build": "npm run compile",
    "build:dev": "npm run compile && npm run package-extension:dev",
    "package-extension": "tfx extension create --manifest-globs azure-devops-extension.json",
    "package-extension:dev": "tfx extension create --manifest-globs azure-devops-extension-dev.json",
    "publish-extension": "tfx extension publish --manifest-globs azure-devops-extension.json",
    "publish-extension:dev": "tfx extension publish --manifest-globs azure-devops-extension-dev.json",
    "test": "jest",
    "clean": "rm -rf dist src/copilot-failure-analysis-task/**/*.js src/copilot-failure-analysis-task/**/*.js.map"
  },
  "dependencies": {
    "azure-pipelines-task-lib": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "tfx-cli": "^0.23.1"
  }
}
